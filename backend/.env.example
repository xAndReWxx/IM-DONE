# ============================================================
# PhysioAI Pro V2 — Backend Environment (template)
# ============================================================
# Copy this to `.env` (same folder) and edit as needed.
# Every key here is optional — sensible defaults live in
# app/config/settings.py.
# ============================================================

# --- Identity ---
APP_NAME="PhysioAI Pro V2"
APP_VERSION=2.0.0
APP_ENV=development           # development | production
DEBUG=true

# --- Network ---
HOST=0.0.0.0
PORT=8000

# --- WebSocket ---
WS_MAX_CONNECTIONS=50
WS_HEARTBEAT_INTERVAL=30
WS_MAX_MESSAGE_SIZE=1048576

# --- Frame processing ---
MAX_FPS=25
TARGET_FPS=20
MAX_FRAME_SIZE_BYTES=524288   # 512 KB

# --- AI thresholds (override the dataset-derived defaults) ---
EMA_ALPHA_LANDMARKS=0.5
FHP_WARN_DEG=22.0
FHP_BAD_DEG=30.0
SHOULDER_TILT_WARN_DEG=5.0
SHOULDER_TILT_BAD_DEG=10.0
SPINE_LEAN_WARN_DEG=6.0
SPINE_LEAN_BAD_DEG=12.0
HOLD_DURATION_SECONDS=3.0

# --- CORS ---
# Comma-separated origins. Use "*" only for local dev.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,*

# --- Logging ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console            # console | json
